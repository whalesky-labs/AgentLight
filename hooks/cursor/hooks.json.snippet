{
  "hooks": {
    "agent:start": [
      {
        "command": "/absolute/path/to/AgentLight/hooks/cursor/agent-light.sh start"
      }
    ],
    "agent:tool": [
      {
        "command": "/absolute/path/to/AgentLight/hooks/cursor/agent-light.sh tool"
      }
    ],
    "agent:thinking": [
      {
        "command": "/absolute/path/to/AgentLight/hooks/cursor/agent-light.sh thinking"
      }
    ],
    "agent:done": [
      {
        "command": "/absolute/path/to/AgentLight/hooks/cursor/agent-light.sh done"
      }
    ],
    "agent:waiting": [
      {
        "command": "/absolute/path/to/AgentLight/hooks/cursor/agent-light.sh waiting"
      }
    ],
    "agent:error": [
      {
        "command": "/absolute/path/to/AgentLight/hooks/cursor/agent-light.sh error"
      }
    ]
  }
}
