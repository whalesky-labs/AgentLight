#!/usr/bin/env python3
"""AgentLight background service runner.

This process is the service entrypoint used by Windows Service wrappers,
macOS LaunchAgent, and Linux user services. It supervises the existing
multi-agent monitor and keeps the hardware bridge running.
"""

from __future__ import annotations

import argparse
import json
import os
import platform
import subprocess
import sys
import time
from datetime import datetime
from pathlib import Path
from typing import Any


REPO_ROOT = Path(__file__).resolve().parents[1]
DEFAULT_CONFIG = REPO_ROOT / "config" / "agentlight-agent.example.json"


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Run the AgentLight background agent.")
    parser.add_argument(
        "command",
        choices=["run", "check-config", "print-runtime", "platform"],
        nargs="?",
        default="run",
    )
    parser.add_argument("platform_action", nargs="?", choices=["get", "list", "set"])
    parser.add_argument("platform_value", nargs="?")
    parser.add_argument("--config", default=os.environ.get("AGENTLIGHT_AGENT_CONFIG", str(DEFAULT_CONFIG)))
    parser.add_argument("--platform", default=os.environ.get("AGENTLIGHT_ACTIVE_PLATFORM", ""))
    parser.add_argument("--once", action="store_true", help="Run one monitor pass and exit. Intended for tests.")
    return parser.parse_args()


def load_config(path: Path) -> dict[str, Any]:
    if not path.exists():
        raise SystemExit(f"Agent config not found: {path}")
    data = json.loads(path.read_text(encoding="utf-8"))
    required = [
        "activePlatform",
        "multiSessionMode",
        "monitorConfig",
        "sendToHardware",
        "pollIntervalSeconds",
        "restartDelaySeconds",
        "environment",
    ]
    for key in required:
        if key not in data:
            raise SystemExit(f"Agent config missing required key: {key}")
    if data["multiSessionMode"] != "latest-event-wins":
        raise SystemExit("Only multiSessionMode=latest-event-wins is supported")
    return data


def save_config(path: Path, config: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(config, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")


def resolve_path(value: str, base: Path) -> Path:
    path = Path(os.path.expanduser(value))
    if not path.is_absolute():
        path = base / path
    return path


def default_log_file() -> Path:
    system = platform.system().lower()
    if system == "windows":
        root = Path(os.environ.get("ProgramData", "C:/ProgramData"))
        return root / "whalesky-labs-AgentLight" / "logs" / "agentlight-agent.log"
    if system == "darwin":
        return Path.home() / "Library" / "Logs" / "whalesky-labs-AgentLight" / "agentlight-agent.log"
    state_home = Path(os.environ.get("XDG_STATE_HOME", Path.home() / ".local" / "state"))
    return state_home / "whalesky-labs-AgentLight" / "agentlight-agent.log"


def open_log(path: Path):
    path.parent.mkdir(parents=True, exist_ok=True)
    return path.open("a", encoding="utf-8", buffering=1)


def log_line(file, message: str) -> None:
    timestamp = datetime.now().astimezone().strftime("%Y-%m-%dT%H:%M:%S%z")
    file.write(f"{timestamp} {message}\n")
    file.flush()


def build_monitor_command(config: dict[str, Any], config_dir: Path, once: bool, platform_name: str) -> list[str]:
    monitor_config = resolve_path(str(config["monitorConfig"]), REPO_ROOT)
    if not monitor_config.exists():
        raise SystemExit(f"Monitor config not found: {monitor_config}")
    command = [
        sys.executable,
        str(REPO_ROOT / "scripts" / "multi-agent-monitor"),
        "--config",
        str(monitor_config),
        "--poll-interval",
        str(config.get("pollIntervalSeconds", 0.5)),
        "--platform",
        platform_name,
    ]
    if config.get("sendToHardware", True):
        command.append("--send")
    if once:
        command.extend(["--once", "--limit", "1"])
    return command


def runtime_info(config_path: Path, config: dict[str, Any]) -> dict[str, str]:
    log_file = resolve_path(config.get("logFile") or str(default_log_file()), config_path.parent)
    monitor_config = resolve_path(str(config["monitorConfig"]), REPO_ROOT)
    if not monitor_config.exists():
        raise SystemExit(f"Monitor config not found: {monitor_config}")
    return {
        "repoRoot": str(REPO_ROOT),
        "config": str(config_path),
        "monitorConfig": str(monitor_config),
        "activePlatform": str(config.get("activePlatform", "")),
        "multiSessionMode": str(config.get("multiSessionMode", "")),
        "logFile": str(log_file),
        "system": platform.system(),
    }


def configured_platforms(config: dict[str, Any]) -> list[str]:
    monitor_config = resolve_path(str(config["monitorConfig"]), REPO_ROOT)
    data = json.loads(monitor_config.read_text(encoding="utf-8"))
    platforms = sorted({str(item["agent"]) for item in data.get("monitors", [])})
    return platforms


def resolve_active_platform(config: dict[str, Any], override: str) -> str:
    platform_name = (override or str(config.get("activePlatform", ""))).strip()
    if not platform_name:
        raise SystemExit("Active platform is not configured")
    return platform_name


def handle_platform_command(config_path: Path, config: dict[str, Any], action: str | None, value: str | None) -> int:
    action = action or "get"
    if action == "get":
        print(config.get("activePlatform", ""))
        return 0
    if action == "list":
        for platform_name in configured_platforms(config):
            marker = "*" if platform_name == config.get("activePlatform") else " "
            print(f"{marker} {platform_name}")
        return 0
    if action == "set":
        if not value:
            raise SystemExit("platform set requires a platform name")
        platforms = configured_platforms(config)
        if value not in platforms:
            raise SystemExit(f"Unknown platform: {value}. Available: {', '.join(platforms)}")
        config["activePlatform"] = value
        save_config(config_path, config)
        print(f"activePlatform={value}")
        return 0
    raise SystemExit(f"Unknown platform action: {action}")


def run_agent(config_path: Path, config: dict[str, Any], once: bool, platform_override: str) -> int:
    log_file = resolve_path(config.get("logFile") or str(default_log_file()), config_path.parent)
    env = os.environ.copy()
    env.update({str(key): str(value) for key, value in config.get("environment", {}).items()})
    env["AGENTLIGHT_AGENT_CONFIG"] = str(config_path)
    env["PYTHONUNBUFFERED"] = "1"

    restart_delay = float(config.get("restartDelaySeconds", 3))
    active_platform = resolve_active_platform(config, platform_override)
    command = build_monitor_command(config, config_path.parent, once, active_platform)

    with open_log(log_file) as log:
        log_line(
            log,
            f"AgentLight agent starting platform={active_platform} mode={config.get('multiSessionMode')} command={command}",
        )
        while True:
            process = subprocess.Popen(
                command,
                cwd=str(REPO_ROOT),
                env=env,
                stdout=log,
                stderr=subprocess.STDOUT,
                text=True,
            )
            return_code = process.wait()
            log_line(log, f"AgentLight monitor exited code={return_code}")
            if once:
                return 0
            time.sleep(restart_delay)
            log_line(log, "Restarting AgentLight monitor")


def main() -> int:
    args = parse_args()
    config_path = resolve_path(args.config, Path.cwd())
    config = load_config(config_path)

    if args.command == "check-config":
        info = runtime_info(config_path, config)
        for key, value in info.items():
            print(f"{key}={value}")
        return 0

    if args.command == "print-runtime":
        print(json.dumps(runtime_info(config_path, config), ensure_ascii=False, indent=2))
        return 0

    if args.command == "platform":
        return handle_platform_command(config_path, config, args.platform_action, args.platform_value)

    return run_agent(config_path, config, args.once, args.platform)


if __name__ == "__main__":
    raise SystemExit(main())
