"""Prepare AgentLight firmware release assets from PlatformIO outputs."""

from __future__ import annotations

import argparse
import hashlib
import json
import os
import re
import shutil
import subprocess
from datetime import datetime, timezone
from pathlib import Path


REQUIRED_BINARIES = {
    "firmware": "firmware.bin",
    "bootloader": "bootloader.bin",
    "partitions": "partitions.bin",
}

FLASH_OFFSETS = {
    "bootloader": "0x0000",
    "partitions": "0x8000",
    "firmware": "0x10000",
}


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Package AgentLight firmware outputs.")
    parser.add_argument("--version", required=True)
    parser.add_argument("--display-version", default="")
    parser.add_argument("--short-version", default="")
    parser.add_argument("--build-number", default="")
    parser.add_argument("--environment", default="esp32-c3-supermini")
    parser.add_argument("--build-channel", choices=["stable", "preview"], default="preview")
    parser.add_argument("--build-dir", default=".pio/build/esp32-c3-supermini")
    parser.add_argument("--dist-dir", default="dist")
    return parser.parse_args()


def file_sha256(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as file:
        for chunk in iter(lambda: file.read(1024 * 1024), b""):
            digest.update(chunk)
    return digest.hexdigest()


def git_output(*args: str) -> str:
    try:
        return subprocess.check_output(["git", *args], text=True).strip()
    except (subprocess.CalledProcessError, FileNotFoundError):
        return ""


def collect_changelog_headings(content: list[str]) -> list[tuple[int, int, str, str]]:
    headings: list[tuple[int, int, str, str]] = []
    for index, line in enumerate(content):
        heading = re.match(r"^(#{2,4})\s+(.+)$", line)
        if heading:
            level = len(heading.group(1))
            title = heading.group(2).strip()
            normalized = title.split(" ", 1)[0].strip()
            normalized = re.sub(r"^\[?([^\]]+)\]?$", r"\1", normalized)
            headings.append((index, level, title, normalized))
    return headings


def section_bounds(
    headings: list[tuple[int, int, str, str]],
    position: int,
    content_length: int,
) -> tuple[int, int]:
    start, level, _, _ = headings[position]
    end = content_length
    for next_start, next_level, _, _ in headings[position + 1 :]:
        if next_level <= level:
            end = next_start
            break
    return start, end


def read_changelog_section(
    content: list[str],
    headings: list[tuple[int, int, str, str]],
    version: str,
    language: str,
    empty_text: str,
) -> tuple[str, str]:
    language_start = 0
    language_end = len(content)
    for position, (_, level, _, normalized) in enumerate(headings):
        if level == 2 and normalized == language:
            language_start, language_end = section_bounds(headings, position, len(content))
            break

    scoped_headings = [
        (index, level, title, normalized)
        for index, level, title, normalized in headings
        if language_start < index < language_end
    ]

    targets = [version, version.lstrip("v"), "Unreleased"]
    for target in targets:
        for position, (start, level, title, normalized) in enumerate(scoped_headings):
            if normalized == target:
                end = language_end
                for next_start, next_level, _, _ in scoped_headings[position + 1 :]:
                    if next_level <= level:
                        end = next_start
                        break
                section = "\n".join(content[start + 1 : end]).strip()
                return title, section or empty_text

    raise SystemExit(f"CHANGELOG {language} section not found for {version} or Unreleased")


def read_changelog_sections(changelog: Path, version: str) -> tuple[str, str, str, str]:
    content = changelog.read_text(encoding="utf-8").splitlines()
    headings = collect_changelog_headings(content)
    zh_title, zh_body = read_changelog_section(
        content,
        headings,
        version,
        "中文",
        "本版本暂无额外发布说明。",
    )
    en_title, en_body = read_changelog_section(
        content,
        headings,
        version,
        "English",
        "No additional release notes for this version.",
    )
    return zh_title, zh_body, en_title, en_body


def render_release_notes(output: Path, values: dict[str, str]) -> None:
    zh_title, zh_body, en_title, en_body = read_changelog_sections(Path("CHANGELOG.md"), values["VERSION"])
    zh_source_title = values["VERSION"] if zh_title == "Unreleased" else zh_title
    en_source_title = values["VERSION"] if en_title == "Unreleased" else en_title
    content = f"""# AgentLight 固件发布说明

## 版本信息

- 版本号：`{values["VERSION"]}`
- 展示版本：`{values["DISPLAY_VERSION"]}`
- 短版本：`{values["SHORT_VERSION"]}`
- 构建号：`{values["BUILD_NUMBER"]}`
- 构建通道：`{values["BUILD_CHANNEL"]}`
- 构建环境：`{values["ENVIRONMENT"]}`
- Git 提交：`{values["GIT_SHA"]}`
- 构建时间：`{values["BUILD_TIME"]}`
- 发布说明来源：`CHANGELOG.md` / `中文:{zh_source_title}` / `English:{en_source_title}`

## 发布说明（中文）

{zh_body}

## Release Notes (English)

{en_body}

## 发布资产

- `firmware.bin`
- `bootloader.bin`
- `partitions.bin`
- `manifest.json`
- `firmware-assets.sha256`

## 烧录提示

1. 下载本次 Release 中的 `firmware.bin`、`bootloader.bin`、`partitions.bin` 和 `manifest.json`。
2. 可用 `firmware-assets.sha256` 校验下载资产。
3. 使用 PlatformIO、esptool 或后续提供的烧录脚本写入 ESP32-C3 SuperMini。
"""
    output.write_text(content, encoding="utf-8")


def main() -> int:
    args = parse_args()
    build_dir = Path(args.build_dir)
    dist_dir = Path(args.dist_dir)

    dist_dir.mkdir(parents=True, exist_ok=True)
    (dist_dir / "firmware-release-notes.md").unlink(missing_ok=True)

    manifest_files = {}
    for label, filename in REQUIRED_BINARIES.items():
        source = build_dir / filename
        if not source.exists():
            raise SystemExit(f"Missing PlatformIO output: {source}")
        target = dist_dir / filename
        shutil.copy2(source, target)
        manifest_files[label] = {
            "file": filename,
            "offset": FLASH_OFFSETS[label],
            "size": target.stat().st_size,
            "sha256": file_sha256(target),
        }

    build_time = datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")
    git_sha = os.environ.get("GITHUB_SHA") or git_output("rev-parse", "HEAD")
    short_version = args.short_version or args.version.removeprefix("v").split("+", 1)[0]
    build_number = args.build_number or (args.version.split("+", 1)[1] if "+" in args.version else "0")
    display_version = args.display_version or f"{short_version} ({build_number})"
    manifest = {
        "project": "AgentLight",
        "version": args.version,
        "displayVersion": display_version,
        "shortVersion": short_version,
        "buildNumber": build_number,
        "environment": args.environment,
        "buildChannel": args.build_channel,
        "buildTime": build_time,
        "gitSha": git_sha,
        "files": manifest_files,
    }
    manifest_path = dist_dir / "manifest.json"
    manifest_path.write_text(
        json.dumps(manifest, indent=2, ensure_ascii=False) + "\n",
        encoding="utf-8",
    )

    release_body_path = dist_dir / "release-body.md"
    render_release_notes(
        release_body_path,
        {
            "VERSION": args.version,
            "DISPLAY_VERSION": display_version,
            "SHORT_VERSION": short_version,
            "BUILD_NUMBER": build_number,
            "ENVIRONMENT": args.environment,
            "BUILD_CHANNEL": args.build_channel,
            "GIT_SHA": git_sha,
            "BUILD_TIME": build_time,
        },
    )

    checksum_path = dist_dir / "firmware-assets.sha256"
    checksum_files = [
        dist_dir / "firmware.bin",
        dist_dir / "bootloader.bin",
        dist_dir / "partitions.bin",
        manifest_path,
    ]
    checksum_path.write_text(
        "".join(f"{file_sha256(path)}  {path.name}\n" for path in checksum_files),
        encoding="utf-8",
    )

    print(f"asset_dir={dist_dir}")
    print(f"manifest={manifest_path}")
    print(f"release_body={release_body_path}")
    print(f"checksum={checksum_path}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
