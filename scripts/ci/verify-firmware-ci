#!/usr/bin/env bash
set -euo pipefail

tmp_dir="$(mktemp -d)"
trap 'rm -rf "$tmp_dir"' EXIT

build_dir="${tmp_dir}/build"
dist_dir="${tmp_dir}/dist"
mkdir -p "$build_dir"

printf 'firmware' > "${build_dir}/firmware.bin"
printf 'bootloader' > "${build_dir}/bootloader.bin"
printf 'partitions' > "${build_dir}/partitions.bin"

grep -Fq 'board_build.flash_size = 4MB' platformio.ini
grep -Fq 'board_build.partitions = huge_app.csv' platformio.ini
grep -Fq 'FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: "true"' .github/workflows/firmware.yml
grep -Fq 'Show firmware release notes' .github/workflows/firmware.yml
grep -Fq 'GITHUB_STEP_SUMMARY' .github/workflows/firmware.yml
grep -Fq '## 中文' CHANGELOG.md
grep -Fq '## English' CHANGELOG.md
grep -Fq '### Unreleased' CHANGELOG.md

test "$(env -u FIRMWARE_VERSION -u GITHUB_REF -u GITHUB_RUN_NUMBER scripts/ci/resolve-firmware-version --version 1.2.3)" = "v1.2.3"
test "$(env -u FIRMWARE_VERSION -u GITHUB_REF -u GITHUB_RUN_NUMBER scripts/ci/resolve-firmware-version --ref refs/tags/v1.2026.051+1775834670)" = "v1.2026.051+1775834670"
test "$(env -u FIRMWARE_VERSION -u GITHUB_REF GITHUB_RUN_NUMBER=1775834670 scripts/ci/resolve-firmware-version)" = "v1.$(date -u +%Y).$(date -u +%j)+1775834670"

metadata="$(GITHUB_RUN_NUMBER=9 scripts/ci/prepare-firmware-release --event-name workflow_dispatch --version v1.2026.051+1775834670 --publish-release true --build-channel 预览构建)"
printf '%s\n' "$metadata" | grep -Fq 'version=v1.2026.051+1775834670'
printf '%s\n' "$metadata" | grep -Fq 'short_version=1.2026.051'
printf '%s\n' "$metadata" | grep -Fq 'build_number=1775834670'
printf '%s\n' "$metadata" | grep -Fq 'display_version=1.2026.051 (1775834670)'
printf '%s\n' "$metadata" | grep -Fq 'build_channel=preview'
printf '%s\n' "$metadata" | grep -Fq 'should_publish=true'
printf '%s\n' "$metadata" | grep -Fq 'is_prerelease=true'
printf '%s\n' "$metadata" | grep -Fq 'tag_name=v1.2026.051+1775834670'
printf '%s\n' "$metadata" | grep -Fq 'release_name=AgentLight Firmware 1.2026.051 (1775834670) Preview'

metadata="$(scripts/ci/prepare-firmware-release --event-name push --ref refs/tags/v1.2026.052+1775834671 --build-channel 正式构建)"
printf '%s\n' "$metadata" | grep -Fq 'build_channel=stable'
printf '%s\n' "$metadata" | grep -Fq 'is_prerelease=false'

scripts/ci/package-firmware \
  --version v0.0.1 \
  --environment test-env \
  --build-channel preview \
  --build-dir "$build_dir" \
  --dist-dir "$dist_dir" >/dev/null

test -f "${dist_dir}/firmware.bin"
test -f "${dist_dir}/bootloader.bin"
test -f "${dist_dir}/partitions.bin"
test -f "${dist_dir}/manifest.json"
test -f "${dist_dir}/firmware-release-notes.md"
test -f "${dist_dir}/firmware-assets.sha256"
grep -Fq 'firmware.bin' "${dist_dir}/firmware-assets.sha256"
grep -Fq 'bootloader.bin' "${dist_dir}/firmware-assets.sha256"
grep -Fq 'partitions.bin' "${dist_dir}/firmware-assets.sha256"
grep -Fq 'manifest.json' "${dist_dir}/firmware-assets.sha256"
grep -Fq '版本号：`v0.0.1`' "${dist_dir}/firmware-release-notes.md"
grep -Fq '展示版本：`0.0.1 (0)`' "${dist_dir}/firmware-release-notes.md"
grep -Fq '短版本：`0.0.1`' "${dist_dir}/firmware-release-notes.md"
grep -Fq '构建号：`0`' "${dist_dir}/firmware-release-notes.md"
grep -Fq '构建通道：`preview`' "${dist_dir}/firmware-release-notes.md"
grep -Fq '发布说明来源：`CHANGELOG.md` / `v0.0.1`' "${dist_dir}/firmware-release-notes.md"
grep -Fq '支持 CI 正式构建和预览构建' "${dist_dir}/firmware-release-notes.md"
if grep -Fq 'This file records AgentLight release notes' "${dist_dir}/firmware-release-notes.md"; then
    printf 'English changelog section leaked into Chinese release notes.\n' >&2
    exit 1
fi

python3 - <<PY
import json
from pathlib import Path

manifest = json.loads(Path("${dist_dir}/manifest.json").read_text(encoding="utf-8"))

if manifest["version"] != "v0.0.1":
    raise SystemExit("manifest version mismatch")
if manifest["displayVersion"] != "0.0.1 (0)":
    raise SystemExit("manifest display version mismatch")
if manifest["shortVersion"] != "0.0.1":
    raise SystemExit("manifest short version mismatch")
if manifest["buildNumber"] != "0":
    raise SystemExit("manifest build number mismatch")
if manifest["buildChannel"] != "preview":
    raise SystemExit("manifest build channel mismatch")
if manifest["files"]["firmware"]["offset"] != "0x10000":
    raise SystemExit("firmware offset mismatch")
if manifest["files"]["bootloader"]["offset"] != "0x0000":
    raise SystemExit("bootloader offset mismatch")
if manifest["files"]["partitions"]["offset"] != "0x8000":
    raise SystemExit("partitions offset mismatch")
PY

printf 'Firmware CI verification passed.\n'
