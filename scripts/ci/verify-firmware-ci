#!/usr/bin/env bash
set -euo pipefail

tmp_dir="$(mktemp -d)"
trap 'rm -rf "$tmp_dir"' EXIT

build_dir="${tmp_dir}/build"
dist_dir="${tmp_dir}/dist"
mkdir -p "$build_dir"

printf 'firmware' > "${build_dir}/firmware.bin"
printf 'bootloader' > "${build_dir}/bootloader.bin"
printf 'partitions' > "${build_dir}/partitions.bin"

test "$(scripts/ci/resolve-firmware-version --version 1.2.3)" = "v1.2.3"
test "$(scripts/ci/resolve-firmware-version --ref refs/tags/v2.0.0)" = "v2.0.0"

metadata="$(GITHUB_RUN_NUMBER=9 scripts/ci/prepare-firmware-release --event-name workflow_dispatch --version v3.0.0 --publish-release true --build-channel preview)"
printf '%s\n' "$metadata" | grep -Fq 'version=v3.0.0'
printf '%s\n' "$metadata" | grep -Fq 'build_channel=preview'
printf '%s\n' "$metadata" | grep -Fq 'should_publish=true'
printf '%s\n' "$metadata" | grep -Fq 'is_prerelease=true'
printf '%s\n' "$metadata" | grep -Fq 'tag_name=v3.0.0'
printf '%s\n' "$metadata" | grep -Fq 'release_name=AgentLight Firmware v3.0.0 Preview'

metadata="$(scripts/ci/prepare-firmware-release --event-name push --ref refs/tags/v4.0.0)"
printf '%s\n' "$metadata" | grep -Fq 'build_channel=stable'
printf '%s\n' "$metadata" | grep -Fq 'is_prerelease=false'

scripts/ci/package-firmware \
  --version v0.0.1 \
  --environment test-env \
  --build-channel preview \
  --build-dir "$build_dir" \
  --dist-dir "$dist_dir" >/dev/null

test -f "${dist_dir}/firmware.bin"
test -f "${dist_dir}/bootloader.bin"
test -f "${dist_dir}/partitions.bin"
test -f "${dist_dir}/manifest.json"
test -f "${dist_dir}/firmware-release-notes.md"
test -f "${dist_dir}/firmware-assets.sha256"
grep -Fq 'firmware.bin' "${dist_dir}/firmware-assets.sha256"
grep -Fq 'bootloader.bin' "${dist_dir}/firmware-assets.sha256"
grep -Fq 'partitions.bin' "${dist_dir}/firmware-assets.sha256"
grep -Fq 'manifest.json' "${dist_dir}/firmware-assets.sha256"
grep -Fq '版本号：`v0.0.1`' "${dist_dir}/firmware-release-notes.md"
grep -Fq '构建通道：`preview`' "${dist_dir}/firmware-release-notes.md"

python3 - <<PY
import json
from pathlib import Path

manifest = json.loads(Path("${dist_dir}/manifest.json").read_text(encoding="utf-8"))

if manifest["version"] != "v0.0.1":
    raise SystemExit("manifest version mismatch")
if manifest["buildChannel"] != "preview":
    raise SystemExit("manifest build channel mismatch")
if manifest["files"]["firmware"]["offset"] != "0x10000":
    raise SystemExit("firmware offset mismatch")
if manifest["files"]["bootloader"]["offset"] != "0x0000":
    raise SystemExit("bootloader offset mismatch")
if manifest["files"]["partitions"]["offset"] != "0x8000":
    raise SystemExit("partitions offset mismatch")
PY

printf 'Firmware CI verification passed.\n'
