"""Prepare firmware CI release metadata."""

from __future__ import annotations

import argparse
import os
import re
import subprocess
import sys


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Prepare AgentLight firmware CI metadata.")
    parser.add_argument("--event-name", default=os.environ.get("GITHUB_EVENT_NAME", ""))
    parser.add_argument("--ref", default=os.environ.get("GITHUB_REF", ""))
    parser.add_argument("--version", default=os.environ.get("INPUT_VERSION", ""))
    parser.add_argument("--publish-release", default=os.environ.get("INPUT_PUBLISH_RELEASE", "false"))
    parser.add_argument("--build-channel", default=os.environ.get("INPUT_BUILD_CHANNEL", ""))
    return parser.parse_args()


def run_resolver(version: str, ref: str) -> str:
    command = [sys.executable, "scripts/ci/resolve-firmware-version", "--version", version, "--ref", ref]
    return subprocess.check_output(command, text=True).strip()


def truthy(value: str) -> bool:
    return value.strip().lower() in {"1", "true", "yes", "y", "on"}


def normalize_build_channel(value: str, is_tag: bool) -> str:
    normalized = value.strip().lower()
    if not normalized:
        return "stable" if is_tag else "preview"

    mapping = {
        "stable": "stable",
        "正式构建": "stable",
        "正式": "stable",
        "release": "stable",
        "preview": "preview",
        "预览构建": "preview",
        "预览": "preview",
        "prerelease": "preview",
    }
    if normalized not in mapping:
        raise SystemExit(f"Invalid build channel: {value}")
    return mapping[normalized]


def split_version(version: str) -> tuple[str, str, str]:
    normalized = version.removeprefix("v")
    if "+" in normalized:
        short_version, build_number = normalized.split("+", 1)
    else:
        short_version, build_number = normalized, ""

    if not build_number:
        match = re.search(r"([0-9]+)$", short_version)
        build_number = match.group(1) if match else "0"

    display_version = f"{short_version} ({build_number})"
    return short_version, build_number, display_version


def main() -> int:
    args = parse_args()
    version = run_resolver(args.version, args.ref)
    short_version, build_number, display_version = split_version(version)
    is_tag = args.ref.startswith("refs/tags/v")
    build_channel = normalize_build_channel(args.build_channel, is_tag)

    manual_publish = args.event_name == "workflow_dispatch" and truthy(args.publish_release)
    should_publish = is_tag or manual_publish
    tag_name = args.ref.removeprefix("refs/tags/") if is_tag else version
    is_prerelease = build_channel == "preview"
    release_name = f"AgentLight Firmware {display_version}"
    if is_prerelease:
        release_name = f"{release_name} Preview"

    print(f"version={version}")
    print(f"short_version={short_version}")
    print(f"build_number={build_number}")
    print(f"display_version={display_version}")
    print(f"build_channel={build_channel}")
    print(f"should_publish={str(should_publish).lower()}")
    print(f"is_prerelease={str(is_prerelease).lower()}")
    print(f"tag_name={tag_name}")
    print(f"release_name={release_name}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
