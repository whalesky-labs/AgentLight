#!/usr/bin/env bash
#
# This file is part of AgentLight.
#
# @link     https://github.com/whalesky-labs/AgentLight
# @document https://github.com/whalesky-labs/AgentLight/blob/main/README.md
# @contact  root@imoi.cn
# @license  https://github.com/whalesky-labs/AgentLight/blob/main/LICENSE
#

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

events=(
  prompt
  user-message
  task-started
  thinking
  function-call
  web-search
  agent-message
  task-complete
  permission-request
  turn-aborted
  idle
)

printf 'Checking shell scripts...\n'
bash -n \
  scripts/agentlight \
  scripts/agentlight-gate \
  scripts/agentlight-event \
  hooks/agents/generic-wrapper.sh \
  hooks/cursor/agent-light.sh \
  service/macos/install-launch-agent.sh \
  service/macos/uninstall-launch-agent.sh

printf 'Checking engineering standards...\n'
test -f AGENTS.md
test -f .editorconfig
test -f docs/code-standards.md
test -f LICENSE
test -f docs/license.md
test -f docs/user-guide.md
grep -Fq 'This file is part of AgentLight.' AGENTS.md
grep -Fq '@license  https://github.com/whalesky-labs/AgentLight/blob/main/LICENSE' AGENTS.md
grep -Fq '@license  https://github.com/whalesky-labs/AgentLight/blob/main/LICENSE' docs/code-standards.md
grep -Fq 'MIT License' LICENSE
grep -Fq 'SPDX 标识为 `MIT`' docs/license.md
grep -Fq 'docs/code-standards.md' README.md
grep -Fq 'docs/code-standards.md' README.en.md
grep -Fq 'docs/license.md' README.md
grep -Fq 'docs/license.md' README.en.md
grep -Fq 'docs/user-guide.md' README.md
grep -Fq 'docs/user-guide.md' README.en.md
grep -Fq '启动电脑端后台服务' docs/user-guide.md
grep -Fq 'Windows 后台服务' docs/user-guide.md
grep -Fq 'macOS 后台服务' docs/user-guide.md
grep -Fq '准备硬件' docs/user-guide.md
grep -Fq '验证硬件' docs/user-guide.md
python3 - <<'PY'
from pathlib import Path

required_license = "@license  https://github.com/whalesky-labs/AgentLight/blob/main/LICENSE"
required = [
    *Path("src").rglob("*.cpp"),
    *Path("include").rglob("*.h"),
    *Path("agentlight_agent").rglob("*.py"),
    *Path("tests").rglob("*.py"),
    Path("scripts/agentlight"),
    Path("scripts/agentlight-agent"),
    Path("scripts/agentlight-event"),
    Path("scripts/agentlight-gate"),
    Path("scripts/multi-agent-monitor"),
    Path("scripts/codex-session-monitor"),
    Path("scripts/verify-agent-bridge"),
    Path("scripts/ci/package-firmware"),
    Path("scripts/ci/prepare-firmware-release"),
    Path("scripts/ci/resolve-firmware-version"),
    Path("scripts/ci/verify-firmware-ci"),
    Path("hooks/agents/generic-wrapper.sh"),
    Path("hooks/cursor/agent-light.sh"),
    Path("service/macos/install-launch-agent.sh"),
    Path("service/macos/uninstall-launch-agent.sh"),
    Path("service/windows/install-service.ps1"),
    Path("service/windows/uninstall-service.ps1"),
]

missing = [
    str(path)
    for path in required
    if "This file is part of AgentLight." not in path.read_text(encoding="utf-8")[:800]
]
if missing:
    raise SystemExit("missing AgentLight file header: " + ", ".join(missing))

missing_license = [
    str(path)
    for path in required
    if required_license not in path.read_text(encoding="utf-8")[:800]
]
if missing_license:
    raise SystemExit("missing AgentLight license header: " + ", ".join(missing_license))

markdown_files = sorted(Path(".").glob("**/*.md"))
allowed_english_markdown = {Path("README.en.md")}
for path in markdown_files:
    if any(part in {".git", ".pio", ".superpowers", "dist"} for part in path.parts):
        continue
    if path in allowed_english_markdown:
        continue
    text = path.read_text(encoding="utf-8")
    forbidden_patterns = [
        "## English",
        "## License",
        "## Build",
        "## Firmware CI",
        "## Bridge Verification",
        "# Multi-Agent Integration",
        "# Codex Hook Notes",
        "# Cursor Hooks",
        "Release Notes (English)",
        "This file records",
        "Use the shared",
        "Wrapper pattern",
        "No automatic",
        "Only synchronizes",
        "Status synchronization only",
    ]
    found = [pattern for pattern in forbidden_patterns if pattern in text]
    if found:
        raise SystemExit(f"non-Chinese markdown content found in {path}: {', '.join(found)}")
PY

printf 'Checking Python monitor...\n'
python3 -m py_compile \
  $(find agentlight_agent -name '*.py' -print) \
  scripts/codex-session-monitor \
  scripts/multi-agent-monitor \
  scripts/agentlight-agent \
  scripts/ci/resolve-firmware-version \
  scripts/ci/prepare-firmware-release \
  scripts/ci/package-firmware

python3 -m unittest discover -s tests -p 'test_*.py'

printf 'Checking firmware CI scripts...\n'
scripts/ci/verify-firmware-ci >/dev/null

printf 'Checking platform registry...\n'
python3 - <<'PY'
import json
from pathlib import Path

path = Path("config/agent-platforms.json")
data = json.loads(path.read_text(encoding="utf-8"))
required = {"name", "canonicalAgent", "aliases", "supportMode", "evidence", "limitations"}
platforms = data.get("platforms", [])
if len(platforms) != 15:
    raise SystemExit(f"expected 15 platforms, got {len(platforms)}")

names = set()
for platform in platforms:
    missing = required - platform.keys()
    if missing:
        raise SystemExit(f"{platform.get('name', '<unknown>')} missing fields: {sorted(missing)}")
    name = platform["name"]
    if name in names:
        raise SystemExit(f"duplicate platform: {name}")
    names.add(name)
    if not platform["aliases"]:
        raise SystemExit(f"{name} has no aliases")
    if not platform["evidence"]:
        raise SystemExit(f"{name} has no evidence")
    if not platform["limitations"].strip():
        raise SystemExit(f"{name} has no limitations text")
    for evidence in platform["evidence"]:
        if not Path(evidence).exists():
            raise SystemExit(f"{name} evidence missing: {evidence}")
PY

printf 'Checking service agent config...\n'
scripts/agentlight-agent check-config --config config/agentlight-agent.example.json >/dev/null
test "$(scripts/agentlight-agent platform get --config config/agentlight-agent.example.json)" = "codex"
scripts/agentlight-agent platform list --config config/agentlight-agent.example.json | grep -Fq '* codex'
monitor_tmp_dir="$(mktemp -d)"
trap 'rm -rf "$monitor_tmp_dir"' EXIT
printf '{"payload":{"type":"task_complete"}}\n' > "$monitor_tmp_dir/codex-session.jsonl"
cat > "$monitor_tmp_dir/agent-monitors.json" <<EOF
{
  "monitors": [
    {
      "name": "ci-codex-session-jsonl",
      "agent": "codex",
      "type": "file",
      "glob": "$monitor_tmp_dir/codex-session.jsonl",
      "format": "jsonl",
      "from_start": true,
      "rules": [
        { "json_path": "payload.type", "equals": "task_complete", "event": "done" }
      ]
    }
  ]
}
EOF
scripts/multi-agent-monitor --config "$monitor_tmp_dir/agent-monitors.json" --platform codex --once --limit 1 >/dev/null
test -f docs/agent-service.md
test -f service/windows/install-service.ps1
test -f service/windows/uninstall-service.ps1
test -f service/macos/install-launch-agent.sh
test -f service/macos/uninstall-launch-agent.sh
grep -Fq 'whalesky-labs-AgentLight' config/agentlight-agent.example.json
grep -Fq '"activePlatform": "codex"' config/agentlight-agent.example.json
grep -Fq '"multiSessionMode": "latest-event-wins"' config/agentlight-agent.example.json
grep -Fq 'whalesky-labs-AgentLight' docs/agent-service.md
grep -Fq 'latest-event-wins' docs/agent-service.md
grep -Fq 'whalesky-labs-AgentLight' service/windows/install-service.ps1
grep -Fq 'whalesky-labs-AgentLight' service/windows/uninstall-service.ps1
grep -Fq 'com.whalesky-labs.AgentLight.agent' service/macos/install-launch-agent.sh
grep -Fq 'com.whalesky-labs.AgentLight.agent' service/macos/uninstall-launch-agent.sh

printf 'Checking agent normalization...\n'
python3 - <<'PY' | while IFS= read -r record; do
import json
from pathlib import Path

data = json.loads(Path("config/agent-platforms.json").read_text(encoding="utf-8"))
for platform in data["platforms"]:
    for alias in platform["aliases"]:
        print(f"{alias}\t{platform['canonicalAgent']}")
PY
  alias="${record%%$'\t'*}"
  expected="${record#*$'\t'}"
  output="$(scripts/agentlight-event --agent "$alias" --event tool-call)"
  case "$output" in
    *"agent=${expected} "*)
      ;;
    *)
      printf 'Alias %s normalized incorrectly. Expected %s, got: %s\n' "$alias" "$expected" "$output" >&2
      exit 1
      ;;
  esac
done

printf 'Checking event normalization...\n'
for event in "${events[@]}"; do
  scripts/agentlight-event --agent codex --event "$event" >/dev/null
done

printf 'Checking documented hook directories...\n'
for dir in \
  hooks/agents \
  hooks/codex \
  hooks/cursor \
  hooks/claude \
  hooks/gemini \
  hooks/qwen \
  hooks/copilot \
  hooks/opencode \
  hooks/kimi \
  hooks/codebuddy \
  hooks/kiro \
  hooks/antigravity \
  hooks/openclaw \
  hooks/hermes \
  hooks/pi; do
  test -f "$dir/README.md"
done

printf 'Checking compatibility matrix...\n'
test -f docs/agent-platform-compatibility.md
python3 - <<'PY'
import json
from pathlib import Path

registry = json.loads(Path("config/agent-platforms.json").read_text(encoding="utf-8"))
matrix = Path("docs/agent-platform-compatibility.md").read_text(encoding="utf-8")
readme = Path("README.md").read_text(encoding="utf-8")
readme_en = Path("README.en.md").read_text(encoding="utf-8")

if "docs/agent-platform-compatibility.md" not in readme:
    raise SystemExit("Chinese README does not link compatibility matrix")
if "docs/agent-platform-compatibility.md" not in readme_en:
    raise SystemExit("English README does not link compatibility matrix")
if "config/agent-platforms.json" not in matrix:
    raise SystemExit("compatibility matrix does not mention platform registry")

for platform in registry["platforms"]:
    name = platform["name"]
    if name not in matrix:
        raise SystemExit(f"matrix missing platform: {name}")
    if platform["supportMode"] not in matrix:
        raise SystemExit(f"matrix missing support mode for {name}: {platform['supportMode']}")
    for evidence in platform["evidence"]:
        if evidence not in matrix:
            raise SystemExit(f"matrix missing evidence for {name}: {evidence}")
PY

printf 'Checking multi-agent monitor config...\n'
scripts/multi-agent-monitor --config config/agent-monitors.example.json --once --limit 1 >/dev/null || true

printf 'AgentLight multi-agent bridge verification passed.\n'
